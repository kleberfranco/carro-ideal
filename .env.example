# Application settings
ENVIRONMENT=development
PORT=8080

# Database settings
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=carro_ideal
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Security settings
SESSION_SECRET=change-me
LOG_LEVEL=debug
ALLOWED_ORIGINS=http://localhost:8080
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
CACHE_TTL_SECONDS=60

# Optional TLS termination in the Go server. Prefer a reverse proxy in production.
TLS_CERT_FILE=
TLS_KEY_FILE=

# OpenAI ChatGPT integration (Phase 2 — TCC core feature)
# Without this key, the system falls back to the scoring algorithm.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=15
