# Application settings
ENVIRONMENT=development
PORT=8080

# Database settings
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=carro_ideal
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Security settings
SESSION_SECRET=change-me
LOG_LEVEL=debug
ALLOWED_ORIGINS=http://localhost:8080
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
CACHE_TTL_SECONDS=60

# Optional TLS termination in the Go server. Prefer a reverse proxy in production.
TLS_CERT_FILE=
TLS_KEY_FILE=
